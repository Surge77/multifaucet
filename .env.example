# ---------------------------------------------------------------------------
# MultiFaucet — environment variables
# Copy to `.env.local` and fill in. NEVER commit real values.
# Only NEXT_PUBLIC_* vars reach the browser; everything else is server-only.
# ---------------------------------------------------------------------------

# --- Server-only (used inside Next.js Route Handlers; never exposed) ---------
# Alchemy: RPC + Token/Transfers APIs. https://dashboard.alchemy.com
ALCHEMY_API_KEY=

# CoinGecko price API (free Demo tier works). https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# Upstash Redis for distributed API rate limiting. https://console.upstash.com
# Optional: when unset, rate limiting falls back to per-instance in-memory.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Faucet claim-voucher signer. The private key signs EIP-712 vouchers in
# /api/faucet-voucher; its ADDRESS must be passed to the contract at deploy time
# (FAUCET_SIGNER_ADDRESS below). Use a dedicated key, never the deployer key.
FAUCET_SIGNER_PRIVATE_KEY=

# Cloudflare Turnstile (captcha) secret — verifies tokens server-side.
# When unset, captcha is skipped in dev and refused in production.
TURNSTILE_SECRET_KEY=

# --- Client-exposed (safe to ship; required by wallet + observability) -------
# WalletConnect Cloud project id. https://cloud.reown.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Web Vitals beacon endpoint for Core Web Vitals reporting (optional).
NEXT_PUBLIC_VITALS_URL=

# Cloudflare Turnstile site key (public). Defaults to the test key in dev.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# --- Contracts: Foundry deploy (used only by forge script, never by the app) -
SEPOLIA_RPC_URL=
BASE_SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_RPC_URL=
# Deployer key for testnet ONLY. Use a throwaway account. Never a real wallet.
DEPLOYER_PRIVATE_KEY=
# Address half of FAUCET_SIGNER_PRIVATE_KEY; passed to the faucet constructor.
FAUCET_SIGNER_ADDRESS=
ETHERSCAN_API_KEY=
BASESCAN_API_KEY=
ARBISCAN_API_KEY=
